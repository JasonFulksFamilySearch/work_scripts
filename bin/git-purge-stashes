#!/bin/sh
self="$0"
while [ -L "$self" ]; do
  dir="$(cd "$(dirname "$self")" && pwd)"
  self="$(readlink "$self")"
  case "$self" in /*) ;; *) self="$dir/$self" ;; esac
done
SCRIPT_DIR="$(cd "$(dirname "$self")" && pwd)"
DEV_SCRIPTS="$(cd "$SCRIPT_DIR/.." && pwd)"
exec "$DEV_SCRIPTS/scripts/git/git_purge_stashes.sh" "$@"
